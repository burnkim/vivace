# Vivace Menu Studio — Supabase sync (cross-device, optional).
# Copy to `.env` and fill in. The anon key is public by design (safe in the
# client). Without these, the studio still runs fully on localStorage.
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<public-anon-key>
VITE_SUPABASE_FUNCTION=make-server-aabb2e08
