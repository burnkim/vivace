# Vivace menu — optional cross-device sync backend.
# Leave unset to run local-first (localStorage only). Set all three to enable
# Supabase sync, then copy this file to `.env`.
#
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_FUNCTION=make-server-aabb2e08
